# Admin Seeded on startup.
ADMIN_PASS=

# Mongo root credentials. REQUIRED — no defaults are provided.
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# The URL for MongoDB. Format: mongodb://[username:password@]host:port/database
# Substitute MONGO_ROOT_USERNAME / MONGO_ROOT_PASSWORD into this value.
MONGO_URL=
MONGO_DB=novellier

# The URL for the ChromaDB vector database API
CHROMA_URL=http://chromadb:8000
OLLAMA_URL=http://ollama:11434
OLLAMA_BASE_URL=http://ollama:11434
AI_PROVIDER=local

EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=gemma2:2b
LLM_TEMPERATURE=0.7 # Controls randomness. Higher = more random, lower = more deterministic.
LLM_NUM_PREDICT=150 # Tokens to predict per response.

# REQUIRED. Generate with: openssl rand -base64 48
# The server will refuse to start with an empty or weak secret.
JWT_SECRET=
JWT_EXPIRATION=3600*24 # JWT token expiration in seconds (1 day).

COMPOSE_PROJECT_NAME=novellier-app
COMPOSE_NETWORK=novellier-app_novellier-network

DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
YOUTRACK_TOKEN=
# Credentials for the dedicated Novellier service account used by the advisor proxy.
# Create this account in Novellier under Admin > Users before starting the profile.
NOVELLIER_ADMIN_USER=app_youtrack_admin
NOVELLIER_ADMIN_PASS=